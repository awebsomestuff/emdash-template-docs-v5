---
interface Heading {
	text: string;
	id: string;
	depth: number;
}

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;
---
<aside class="docs-toc">
	<div class="toc-title">On this page</div>
	<ul class="toc-list">
		{headings.map(h => (
			<li>
				<a
					href={`#${h.id}`}
					class:list={["toc-link", { "depth-3": h.depth === 3 }]}
					data-toc-id={h.id}
				>
					{h.text}
				</a>
			</li>
		))}
	</ul>
</aside>

<script is:inline>
	(function () {
		var links = document.querySelectorAll("[data-toc-id]");
		if (!links.length) return;

		var ids = Array.from(links).map(function (l) { return l.getAttribute("data-toc-id"); });
		var observer = new IntersectionObserver(function (entries) {
			entries.forEach(function (entry) {
				if (entry.isIntersecting) {
					links.forEach(function (l) { l.classList.remove("active"); });
					var active = document.querySelector('[data-toc-id="' + entry.target.id + '"]');
					if (active) active.classList.add("active");
				}
			});
		}, { rootMargin: "-80px 0px -70% 0px", threshold: 0 });

		ids.forEach(function (id) {
			var el = document.getElementById(id);
			if (el) observer.observe(el);
		});
	})();
</script>
