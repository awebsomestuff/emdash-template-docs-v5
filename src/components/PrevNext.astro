---
interface NavDoc {
	slug: string;
	title: string;
}

interface Props {
	prev?: NavDoc | null;
	next?: NavDoc | null;
}

const { prev, next } = Astro.props;
---
{(prev || next) && (
	<nav class="prev-next">
		{prev && (
			<a href={`/docs/${prev.slug}`} class="prev-next-link prev">
				<span class="prev-next-label">&larr; Previous</span>
				<span class="prev-next-title">{prev.title}</span>
			</a>
		)}
		{next && (
			<a href={`/docs/${next.slug}`} class="prev-next-link next">
				<span class="prev-next-label">Next &rarr;</span>
				<span class="prev-next-title">{next.title}</span>
			</a>
		)}
	</nav>
)}
